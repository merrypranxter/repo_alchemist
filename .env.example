# VITE_GEMINI_API_KEY: Your Gemini API key.
# Used for all Gemini AI calls (vibe fusion + image generation).
# Can also be set at runtime via the "Set Key" button in the app UI
# (stored in browser localStorage — never leaves your browser).
VITE_GEMINI_API_KEY=

# VITE_GITHUB_TOKEN: Personal Access Token for GitHub API (optional).
# Used to fetch repository metadata and READMEs.
# Without it, public repos still work but you may hit rate limits.
VITE_GITHUB_TOKEN=
