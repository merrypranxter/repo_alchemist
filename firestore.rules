rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: renders
    // Document ID: auto-generated
    // Fields:
    //   - userId: string (required) - The UID of the user who generated the image.
    //   - prompt: string (required) - The user's original text prompt.
    //   - negPrompt: string (optional) - The negative prompt used.
    //   - fusedPrompt: string (optional) - The final prompt fused with repository context.
    //   - repos: list (required) - The list of repository names mixed for this generation.
    //   - model: string (optional) - The model used for generation.
    //   - aspectRatio: string (optional) - The aspect ratio of the generated images.
    //   - resolution: string (optional) - The target resolution.
    //   - qualityPreset: string (optional) - The quality preset applied.
    //   - lighting: string (optional) - The lighting style applied.
    //   - renderStyle: string (optional) - The rendering style applied.
    //   - images: list (required) - The generated images stored as base64 strings.
    //   - createdAt: timestamp (required) - When the render was created.
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "marygray.art@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidRender(data) {
      return data.keys().hasAll(['userId', 'prompt', 'repos', 'images', 'createdAt']) &&
             data.userId is string &&
             data.prompt is string && data.prompt.size() < 5000 &&
             data.repos is list && data.repos.size() < 50 &&
             data.images is list && data.images.size() < 10 &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /renders/{renderId} {
      // Users can only read their own renders
      allow read: if isOwner(resource.data.userId) || isAdmin();
      
      // Users can only create renders for themselves
      allow create: if isOwner(request.resource.data.userId) && isValidRender(request.resource.data);
      
      // Renders are immutable
      allow update, delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isAdmin();
    }
  }
}
